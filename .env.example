# ============================================
# RoadHouse v5 — Environment Variables
# Copy this to .env.local and fill in values
# ============================================

# App URL (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# STRIPE
# Get these from: https://dashboard.stripe.com
# ============================================

# Secret key (server-side only — NEVER expose in client code)
STRIPE_SECRET_KEY=sk_live_...

# Publishable key (safe to expose in browser)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Webhook secret (from Stripe Dashboard > Webhooks)
# For local testing: stripe listen --forward-to localhost:3000/api/webhook
STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================
# STRIPE PRODUCT PRICE IDs
# Create products in Stripe Dashboard first,
# then paste the price IDs here.
# ============================================

# --- Merch (one-time) ---
NEXT_PUBLIC_STRIPE_PRICE_TEE=price_...
NEXT_PUBLIC_STRIPE_PRICE_HAT=price_...
NEXT_PUBLIC_STRIPE_PRICE_HOODIE=price_...
NEXT_PUBLIC_STRIPE_PRICE_STICKERS=price_...
NEXT_PUBLIC_STRIPE_PRICE_GLASS=price_...
NEXT_PUBLIC_STRIPE_PRICE_PHONE=price_...

# --- Memberships (recurring) ---
NEXT_PUBLIC_STRIPE_SUB_REGULAR=price_...
NEXT_PUBLIC_STRIPE_SUB_RANCH=price_...
NEXT_PUBLIC_STRIPE_SUB_PARTNER=price_...

# --- Event Tickets (one-time) ---
NEXT_PUBLIC_STRIPE_PRICE_SKMT=price_...
NEXT_PUBLIC_STRIPE_PRICE_SUMMIT=price_...

# --- Sponsorship Packages (one-time or recurring) ---
NEXT_PUBLIC_STRIPE_PRICE_SPONSOR_TB=price_...
NEXT_PUBLIC_STRIPE_PRICE_SPONSOR_FR=price_...
NEXT_PUBLIC_STRIPE_PRICE_SPONSOR_PR=price_...

# ============================================
# OPTIONAL: Discord Bot (for role automation)
# ============================================
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_ROLE_REGULAR=
DISCORD_ROLE_RANCH_HAND=
DISCORD_ROLE_PARTNER=
